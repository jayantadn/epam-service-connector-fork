#cloud-config
hostname: vm2

users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: users, admin, docker
    home: /home/ubuntu
    shell: /bin/bash
    lock_passwd: false
    lock_passwd: false

ssh_pwauth: true
chpasswd:
  expire: false
  users:
    - name: ubuntu
      password: ubuntu
      type: text
  users:
    - name: ubuntu
      password: ubuntu
      type: text

packages:
  - iputils-ping
  - build-essential
  - g++
  - cmake
  - git
  - pkg-config
  - protobuf-compiler
  - protobuf-compiler-grpc
  - libprotobuf-dev
  - libgrpc++-dev
  - net-tools
  - iproute2
  - curl
  - python3
  - python3-pip
  - python3-full

write_files:
  # Force password SSH login on. Highest-numbered drop-in wins over
  # any default cloud-image overrides (e.g. 60-cloudimg-settings.conf).
  - path: /etc/ssh/sshd_config.d/99-evrange-pwauth.conf
    permissions: '0644'
    owner: root:root
    content: |
      PasswordAuthentication yes
      KbdInteractiveAuthentication yes
      PermitRootLogin no

runcmd:
  # Make sure sshd picks up the password-auth drop-in written above.
  - systemctl restart ssh

  # Refresh linker cache for gRPC libs (used by C++ apps).
  - ldconfig

  # Install Python packages required by the EV Range Extender VM2 components.
  # Runtime is on VM1 only. VM2 ECUs act as bridge-edge adapters and
  # transfer all VM1<->VM2 signal data via kuksa-bridge over Zenoh.
  # kuksa-client is pinned because the ECUs import Datapoint from
  # kuksa_client.grpc, which is the 0.5.x API shape.
  - |
    pip3 install --break-system-packages --ignore-installed \
      eclipse-zenoh 'someipy>=1.0,<2.0' pyyaml jsonschema grpcio grpcio-tools 'kuksa-client==0.5.1' \
      >> /tmp/evrange-pip.log 2>&1 || \
      echo "WARNING: pip install reported errors, see /tmp/evrange-pip.log" >> /tmp/evrange-pip.log

  # Create a generic apps directory for ad-hoc deployments.
  - mkdir -p /home/ubuntu/apps
  - chown -R ubuntu:ubuntu /home/ubuntu/apps
