#cloud-config
hostname: vm1

users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: users, admin, docker
    home: /home/ubuntu
    shell: /bin/bash
    lock_passwd: false

ssh_pwauth: true
chpasswd:
  expire: false
  users:
    - name: ubuntu
      password: ubuntu
      type: text

packages:
  - iputils-ping
  - docker.io
  - python3
  - python3-pip
  - python3-full
  - net-tools
  - iproute2
  - curl

write_files:
  # Force password SSH login on. Highest-numbered drop-in wins over
  # any default cloud-image overrides (e.g. 60-cloudimg-settings.conf).
  - path: /etc/ssh/sshd_config.d/99-xmel-pwauth.conf
    permissions: '0644'
    owner: root:root
    content: |
      PasswordAuthentication yes
      KbdInteractiveAuthentication yes
      PermitRootLogin no

  # Robust SDV Runtime startup script with retries, health checks and dedicated log file.
  # Re-runnable manually: sudo /usr/local/bin/xmel-start-runtime
  - path: /usr/local/bin/xmel-start-runtime
    permissions: '0755'
    owner: root:root
    content: |
      #!/usr/bin/env bash
      # XMEL SDV Runtime startup helper.
      # Pulls and starts the digital.auto SDV Runtime (Kuksa Databroker + cloud sync)
      # with retries and a health check on the gRPC port.
      set -uo pipefail

      LOG_FILE="/tmp/xmel-runtime.log"
      CONTAINER="sdv-runtime"
      IMAGE="ghcr.io/eclipse-autowrx/sdv-runtime:latest"
      RUNTIME_NAME="${RUNTIME_NAME:-ev-range}"
      DATABROKER_PORT="${DATABROKER_PORT:-55555}"
      MAX_PULL_ATTEMPTS="${MAX_PULL_ATTEMPTS:-5}"
      PULL_BACKOFF_SECS="${PULL_BACKOFF_SECS:-10}"
      MAX_HEALTH_ATTEMPTS="${MAX_HEALTH_ATTEMPTS:-45}"   # 45 * 2s = 90s
      DOCKER_WAIT_ATTEMPTS="${DOCKER_WAIT_ATTEMPTS:-30}" # 30 * 2s = 60s

      log() {
          local ts
          ts=$(date '+%Y-%m-%d %H:%M:%S.%3N')
          echo "[$ts] [runtime] $*" | tee -a "$LOG_FILE"
      }

      ensure_docker() {
          if ! command -v docker >/dev/null 2>&1; then
              log "ERROR: docker is not installed"
              exit 1
          fi
          log "Waiting for docker daemon to be active..."
          for i in $(seq 1 "$DOCKER_WAIT_ATTEMPTS"); do
              if systemctl is-active --quiet docker && docker info >/dev/null 2>&1; then
                  log "Docker daemon is up"
                  return 0
              fi
              sleep 2
          done
          log "ERROR: docker daemon did not become active in time"
          systemctl status docker --no-pager 2>&1 | tee -a "$LOG_FILE" || true
          exit 1
      }

      check_network() {
          log "Checking outbound network to ghcr.io..."
          if curl -fsS --max-time 10 -o /dev/null https://ghcr.io 2>>"$LOG_FILE"; then
              log "Network OK"
              return 0
          fi
          log "WARNING: ghcr.io not reachable yet, will still try to pull"
          return 0
      }

      cleanup_stale_container() {
          if docker ps -a --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
              log "Removing existing '$CONTAINER' container (stale or previous run)..."
              docker rm -f "$CONTAINER" >>"$LOG_FILE" 2>&1 || true
          fi
      }

      pull_image() {
          for attempt in $(seq 1 "$MAX_PULL_ATTEMPTS"); do
              log "Pulling $IMAGE (attempt $attempt/$MAX_PULL_ATTEMPTS)..."
              if docker pull "$IMAGE" >>"$LOG_FILE" 2>&1; then
                  log "Pull successful"
                  return 0
              fi
              log "Pull failed, sleeping ${PULL_BACKOFF_SECS}s before retry..."
              sleep "$PULL_BACKOFF_SECS"
          done
          log "ERROR: Could not pull $IMAGE after $MAX_PULL_ATTEMPTS attempts"
          return 1
      }

      start_container() {
          log "Starting container '$CONTAINER' (RUNTIME_NAME=$RUNTIME_NAME, --network host)..."
          if ! docker run -d \
                  --name "$CONTAINER" \
                  --restart unless-stopped \
                  --network host \
                  -e RUNTIME_NAME="$RUNTIME_NAME" \
                  "$IMAGE" >>"$LOG_FILE" 2>&1; then
              log "ERROR: docker run failed"
              return 1
          fi
          log "Container started"
          return 0
      }

      wait_for_databroker() {
          log "Waiting for Kuksa Databroker on port $DATABROKER_PORT (max $((MAX_HEALTH_ATTEMPTS*2))s)..."
          for i in $(seq 1 "$MAX_HEALTH_ATTEMPTS"); do
              if ! docker ps --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
                  log "ERROR: Container '$CONTAINER' died unexpectedly"
                  log "----- container status -----"
                  docker ps -a --filter "name=$CONTAINER" 2>&1 | tee -a "$LOG_FILE"
                  log "----- last container logs -----"
                  docker logs --tail 80 "$CONTAINER" 2>&1 | tee -a "$LOG_FILE" || true
                  return 1
              fi
              if ss -ltn 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${DATABROKER_PORT}\$"; then
                  log "Kuksa Databroker is listening on port $DATABROKER_PORT"
                  return 0
              fi
              sleep 2
          done
          log "ERROR: Databroker did not become reachable on port $DATABROKER_PORT in time"
          log "----- container status -----"
          docker ps -a --filter "name=$CONTAINER" 2>&1 | tee -a "$LOG_FILE"
          log "----- last container logs -----"
          docker logs --tail 80 "$CONTAINER" 2>&1 | tee -a "$LOG_FILE" || true
          return 1
      }

      main() {
          : > "$LOG_FILE" 2>/dev/null || true
          log "============================================================"
          log "             XMEL SDV Runtime Startup (VM1)"
          log "============================================================"
          log "Image          : $IMAGE"
          log "Container name : $CONTAINER"
          log "Runtime name   : $RUNTIME_NAME"
          log "Databroker port: $DATABROKER_PORT"
          log "Log file       : $LOG_FILE"
          log "Re-run         : sudo /usr/local/bin/xmel-start-runtime"
          log "============================================================"

          ensure_docker
          check_network
          cleanup_stale_container

          if ! pull_image; then
              log "Pull failed permanently - giving up"
              exit 2
          fi
          if ! start_container; then
              log "Start failed - giving up"
              exit 3
          fi
          if ! wait_for_databroker; then
              log "Health check failed - container is up but databroker is not responding"
              log "Try: sudo /usr/local/bin/xmel-start-runtime  (will recreate the container)"
              exit 4
          fi

          log "============================================================"
          log "SUCCESS: SDV Runtime is up and healthy"
          log "  Runtime container logs : docker logs -f $CONTAINER"
          log "  This startup log       : tail -f $LOG_FILE"
          log "============================================================"
      }

      main "$@"

runcmd:
  - usermod -aG docker ubuntu

  # Make sure sshd picks up the password-auth drop-in written above.
  - systemctl restart ssh

  # Install Python packages required by xmel-client and Python apps.
  - |
    pip3 install --break-system-packages --ignore-installed kuksa-client grpcio grpcio-tools \
      eclipse-zenoh pyyaml jsonschema requests packaging \
      >> /tmp/xmel-pip.log 2>&1 || \
      echo "WARNING: pip install reported errors, see /tmp/xmel-pip.log" >> /tmp/xmel-pip.log

  # Start the SDV Runtime via the helper script. Background with & so cloud-init
  # does not block forever if the network is slow or ghcr.io is throttled.
  - /usr/local/bin/xmel-start-runtime &

  # Create apps directory for xmel-client deployments.
  - mkdir -p /home/ubuntu/apps
  - chown -R ubuntu:ubuntu /home/ubuntu/apps
