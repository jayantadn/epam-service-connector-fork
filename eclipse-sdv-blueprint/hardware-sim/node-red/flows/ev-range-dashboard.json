  {
    "id": "ev-range-fan-anim",
    "type": "ui-template",
    "z": "ev-range-tab",
    "group": "ev-range-group-fan",
    "page": "",
    "ui": "",
    "name": "Fan animation",
    "order": 1,
    "width": "3",
    "height": "6",
    "head": "",
    "format": "<template>\n  <div class=\"fan-wrap\">\n    <svg :class=\"['fan-svg', { spinning: !off }]\" :style=\"svgStyle\" viewBox=\"0 0 120 120\">\n      <defs>\n        <radialGradient :id=\"'fan-housing-'+uid\" cx=\"50%\" cy=\"40%\" r=\"60%\">\n          <stop offset=\"0%\" stop-color=\"#3a3a3a\" />\n          <stop offset=\"100%\" stop-color=\"#0a0a0a\" />\n        </radialGradient>\n        <linearGradient :id=\"'fan-blade-'+uid\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n          <stop offset=\"0%\" :stop-color=\"bladeHi\" />\n          <stop offset=\"100%\" :stop-color=\"bladeLo\" />\n        </linearGradient>\n        <radialGradient :id=\"'fan-hub-'+uid\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n          <stop offset=\"0%\" stop-color=\"#bbb\" />\n          <stop offset=\"100%\" stop-color=\"#222\" />\n        </radialGradient>\n        <filter :id=\"'fan-glow-'+uid\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n          <feGaussianBlur stdDeviation=\"3\" result=\"b\" />\n          <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n        </filter>\n      </defs>\n      <circle cx=\"60\" cy=\"60\" r=\"58\" :fill=\"'url(#fan-housing-'+uid+')'\" stroke=\"#555\" stroke-width=\"2\" />\n      <circle cx=\"60\" cy=\"60\" r=\"52\" fill=\"none\" stroke=\"#1a1a1a\" stroke-width=\"1\" />\n      <g :fill=\"'url(#fan-blade-'+uid+')'\" :filter=\"glowing?'url(#fan-glow-'+uid+')':''\" opacity=\"0.95\">\n        <path d=\"M60 60 C 70 30, 70 18, 60 8 C 50 18, 50 30, 60 60 Z\" />\n        <path d=\"M60 60 C 90 50, 102 50, 112 60 C 102 70, 90 70, 60 60 Z\" />\n        <path d=\"M60 60 C 50 90, 50 102, 60 112 C 70 102, 70 90, 60 60 Z\" />\n        <path d=\"M60 60 C 30 70, 18 70, 8 60 C 18 50, 30 50, 60 60 Z\" />\n      </g>\n      <circle cx=\"60\" cy=\"60\" r=\"10\" :fill=\"'url(#fan-hub-'+uid+')'\" stroke=\"#000\" stroke-width=\"1.5\" />\n      <circle cx=\"60\" cy=\"60\" r=\"3\" fill=\"#000\" />\n    </svg>\n    <div class=\"fan-meta\">\n      <div class=\"fan-value\" :style=\"{ color: bladeHi, textShadow: glowing ? `0 0 12px ${bladeHi}` : 'none' }\">{{ valueLabel }}</div>\n      <div class=\"fan-sublabel\">{{ rpmLabel }}</div>\n    </div>\n    <!-- hidden style injector: recolors fan slider when speed===0 -->\n    <component :is=\"'style'\">.fan-slider .v-slider-track__background, .fan-slider .v-slider-track__background--opacity { background: {{ trackColor }} !important; opacity: 1 !important; } .fan-slider .v-slider-track__fill { background: {{ fillColor }} !important; } .fan-slider .v-slider-thumb__surface { background: {{ fillColor }} !important; } .fan-slider .v-icon { color: {{ fillColor }} !important; }</component>\n  </div>\n</template>\n<style>\n.fan-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:4px 4px;width:100%;}\n.fan-svg{width:140px;height:140px;min-width:140px;min-height:140px;max-width:140px;max-height:140px;flex:0 0 140px;aspect-ratio:1/1;transform-origin:50% 50%;filter:drop-shadow(0 4px 10px rgba(0,0,0,0.6));}\n.fan-svg.spinning{animation:fan-spin var(--fan-dur,2s) linear infinite;}\n@keyframes fan-spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}\n.fan-meta{display:flex;flex-direction:column;align-items:center;margin-top:4px;font-family:'Roboto Mono',monospace;}\n.fan-value{font-size:22px;font-weight:900;letter-spacing:2px;transition:all 0.3s;}\n.fan-sublabel{font-size:13px;letter-spacing:4px;color:#999;margin-top:2px;}\n</style>\n<script>\nexport default {\n  data(){return {engineOn:false,speed:0,uid:Math.random().toString(36).slice(2,8)}},\n  computed:{\n    svgStyle(){const s=Math.max(1,this.speed);const dur=Math.max(0.18,2.6-(s/100)*2.42);return {'--fan-dur':dur+'s'}},\n    glowing(){return this.speed>0},\n    bladeHi(){if(this.speed===0)return '#666';if(this.speed<33)return '#3498db';if(this.speed<66)return '#ff6b35';return '#e74c3c'},\n    bladeLo(){if(this.speed===0)return '#333';if(this.speed<33)return '#1a4a6b';if(this.speed<66)return '#7a3215';return '#7a1d12'},\n    rpmLabel(){if(!this.engineOn||this.speed===0)return 'IDLE';if(this.speed<33)return 'LOW';if(this.speed<66)return 'MEDIUM';return 'HIGH'},\n    trackColor(){return this.speed===0?'rgba(231,76,60,0.35)':'rgba(255,107,53,0.30)'},\n    fillColor(){return this.speed===0?'#e74c3c':'#ff6b35'},\n    off(){return !this.engineOn||this.speed===0},\n    valueLabel(){return this.off?'OFF':this.speed+'%'}\n  },\n  watch:{msg:{handler(m){if(!m||m.payload==null)return;if(m.topic==='drive'){this.engineOn=!!m.payload;return;}const n=Number(m.payload);if(!isNaN(n))this.speed=Math.max(0,Math.min(100,Math.round(n)));},deep:true,immediate:true}}\n}\n</script>",
    "storeOutMessages": true,
    "passthru": false,
    "resendOnRefresh": true,
    "templateScope": "local",
