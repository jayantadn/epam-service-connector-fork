  {
    "id": "ev-range-resync-on-connect",
    "type": "function",
    "z": "ev-range-tab",
    "name": "Force resync to new client",
    "func": "// Clear the change-tracking snapshot so the next /state poll\n// re-emits every value to the freshly connected widgets.\nflow.set('lastStatusSnap', null);\nreturn null;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 400,
    "y": 110,
    "wires": [
      []
    ]
  },
  {
    "id": "ev-range-init-func",
    "type": "function",
    "z": "ev-range-tab",
    "name": "Publish startup defaults",
    "func": "// Mirror pytk_dashboard.py _publish_startup_defaults (T+1s).\nflow.set('soc', 80);\nflow.set('voltage', 380);\nflow.set('current', 30);\nflow.set('hvacValue', 0);\nflow.set('heatOn', false);\nflow.set('coolOn', false);\nflow.set('driveOn', false);\nflow.set('autoActionDone', false);\n\nconst defaults = [\n  { key: 'sim/battery/voltage', value: 380 },\n  { key: 'sim/battery/current', value: 30 },\n  { key: 'sim/battery/soc', value: 80 },\n  { key: 'sim/cabin/temp', value: 0 },\n  { key: 'sim/cabin/seat/heating', value: 0 },\n  { key: 'sim/cabin/seat/hc', value: 0 }\n];\n\n// Space publishes ~60ms apart so http-request node processes each cleanly.\ndefaults.forEach((d, i) => {\n  setTimeout(() => {\n    node.send([{ payload: d }, null]);\n  }, i * 60);\n});\n\n// After all defaults sent, kick the auto-action via output 2.\nsetTimeout(() => {\n  node.send([null, { payload: 'go' }]);\n}, defaults.length * 60 + 400);\n\nreturn null;",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 60,
    "wires": [
      [
        "ev-range-http-publish"
      ],
      [
        "ev-range-init-auto-action"
      ]
    ]
  },
  {
    "id": "ev-range-init-auto-action",
    "type": "function",
    "z": "ev-range-tab",
    "name": "Auto action (fan=30, cool=ON)",
    "func": "// Mirror pytk_dashboard.py _apply_default_user_action (T+1.4s).\nif (flow.get('autoActionDone')) return null;\nflow.set('autoActionDone', true);\n\nflow.set('hvacValue', 30);\nflow.set('coolOn', true);\nflow.set('heatOn', false);\n\n// Stagger the 3 publishes ~60ms apart.\nconst pubs = [\n  { key: 'sim/cabin/temp', value: 30 },\n  { key: 'sim/cabin/seat/heating', value: 0 },\n  { key: 'sim/cabin/seat/hc', value: -100 }\n];\npubs.forEach((p, i) => {\n  setTimeout(() => {\n    node.send([{ payload: p }, null, null]);\n  }, i * 60);\n});\n\n// Sync UI controls.\nsetTimeout(() => node.send([null, { payload: 30 }, null]), 50);\nsetTimeout(() => node.send([null, null, { payload: true }]), 50);\n\nreturn null;",
    "outputs": 3,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 700,
    "y": 60,
    "wires": [
      [
        "ev-range-http-publish"
      ],
      [
        "ev-range-slider-hvac"
      ],
      [
        "ev-range-switch-cool"
      ]
    ]
  },
  {
    "id": "ev-range-drive-button",
    "type": "ui-template",
    "z": "ev-range-tab",
    "group": "ev-range-group-drive",
    "page": "",
    "ui": "",
    "name": "Engine Start/Stop",
    "order": 0,
    "width": "3",
    "height": "6",
    "head": "",
    "format": "<template>\n  <div class=\"engine-btn-wrap\" @click=\"toggle\">\n    <div class=\"engine-btn-outer\" :class=\"{ on: on }\">\n      <div class=\"engine-btn-bezel\">\n        <div class=\"engine-btn-inner\">\n          <div class=\"engine-btn-line line1\">ENGINE</div>\n          <div class=\"engine-btn-line line2\">START</div>\n          <div class=\"engine-btn-line line3\">STOP</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"engine-btn-status\" :class=\"{ on: on }\">{{ on ? 'ENGINE ON' : 'PRESS TO START' }}</div>\n  </div>\n</template>\n<style>\n.engine-btn-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;user-select:none;padding:2px;width:100%;}\n.engine-btn-outer{width:170px;height:170px;min-width:170px;min-height:170px;max-width:170px;max-height:170px;flex:0 0 170px;aspect-ratio:1/1;box-sizing:border-box;border-radius:50%;background:radial-gradient(circle at 50% 35%, #4a4a4a 0%, #1a1a1a 70%);padding:6px;box-shadow:0 6px 14px rgba(0,0,0,0.6), inset 0 -3px 6px rgba(0,0,0,0.5), inset 0 3px 6px rgba(255,255,255,0.08);transition:all 0.2s ease;border:2px solid #b22222;}\n.engine-btn-outer.on{border-color:#27ae60;box-shadow:0 0 30px rgba(39,174,96,0.6), inset 0 -4px 8px rgba(0,0,0,0.5);}\n.engine-btn-outer:active{transform:translateY(2px);box-shadow:0 4px 10px rgba(0,0,0,0.6), inset 0 4px 8px rgba(0,0,0,0.6);}\n.engine-btn-bezel{width:100%;height:100%;box-sizing:border-box;border-radius:50%;background:linear-gradient(145deg,#2b2b2b,#101010);padding:8px;border:1px solid #555;}\n.engine-btn-inner{width:100%;height:100%;box-sizing:border-box;border-radius:50%;background:radial-gradient(circle at 50% 40%, #c0392b 0%, #7a1d12 80%);display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;font-family:'Arial Black','Helvetica',sans-serif;text-shadow:0 1px 2px rgba(0,0,0,0.8);box-shadow:inset 0 -6px 12px rgba(0,0,0,0.5), inset 0 6px 12px rgba(255,255,255,0.15);transition:background 0.3s;}\n.engine-btn-outer.on .engine-btn-inner{background:radial-gradient(circle at 50% 40%, #27ae60 0%, #145a32 80%);}\n.engine-btn-line{font-weight:900;letter-spacing:1px;line-height:1.05;}\n.line1{font-size:13px;opacity:0.85;}\n.line2{font-size:22px;}\n.line3{font-size:13px;opacity:0.85;}\n.engine-btn-status{margin-top:6px;font-family:monospace;font-size:13px;font-weight:bold;letter-spacing:1px;color:#888;}\n.engine-btn-status.on{color:#27ae60;}\n</style>\n<script>\nexport default {\n  data(){return {on:false}},\n  watch:{msg(m){if(m&&typeof m.payload==='boolean')this.on=m.payload}},\n  methods:{toggle(){this.on=!this.on;this.send({payload:this.on})}}\n}\n</script>",
    "storeOutMessages": true,
    "passthru": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 160,
    "y": 100,
    "wires": [
      [
        "ev-range-drive-handle"
      ]
    ]
  },
  {
    "id": "ev-range-drive-handle",
    "type": "function",
    "z": "ev-range-tab",
    "name": "Toggle drive",
    "func": "const on = !!msg.payload;\nconst prev = !!flow.get('driveOn');\nflow.set('driveOn', on);\nconst fanMsg = { payload: on, topic: 'drive' };\nconst started = flow.get('engineStarted');\nif (!prev && on) {\n  flow.set('engineStarted', true);\n  return [fanMsg, { payload: { text: 'Engine turned ON', kind: 'on' } }];\n}\nif (prev && !on && started) {\n  return [fanMsg, { payload: { text: 'Engine turned OFF', kind: 'off' } }];\n}\nreturn [fanMsg, null];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 140,
    "wires": [
      [
        "ev-range-fan-anim"
      ],
      [
        "ev-range-notify"
      ]
    ]
  },
  {
