  {
    "id": "ev-range-drive-step",
    "type": "function",
    "z": "ev-range-tab",
    "name": "Drain SoC",
    "func": "if (!flow.get('driveOn')) return null;\nlet soc = Number(flow.get('soc') || 0);\nsoc = Math.max(0, soc - 1);\nflow.set('soc', soc);\nif (soc <= 0) {\n  flow.set('driveOn', false);\n  return [\n    { payload: { key: 'sim/battery/soc', value: 0 } },\n    { payload: 'Idle - battery depleted' },\n    { payload: 0 }\n  ];\n}\nreturn [\n  { payload: { key: 'sim/battery/soc', value: soc } },\n  null,\n  { payload: soc }\n];",
    "outputs": 3,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 320,
    "y": 200,
    "wires": [
