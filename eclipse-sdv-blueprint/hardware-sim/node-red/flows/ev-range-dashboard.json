  {
    "id": "ev-range-update-status",
    "type": "function",
    "z": "ev-range-flow",
    "name": "Build status text",
    "func": "const payload = msg.payload || {};\nconst statuses = payload.statuses || {};\nconst signals = payload.signals || {};\n\n// ----- HVAC -----\nconst hvacStatus = statuses['dash/status/hvac'];\nlet hvacOn = false;\nlet hvacVal = 0;\nlet hvacText = 'awaiting ECU...';\nlet hvacSrc = '?';\nif (hvacStatus) {\n  if (hvacStatus.value !== undefined && hvacStatus.value !== null) {\n    hvacVal = Number(hvacStatus.value) || 0;\n    hvacOn = hvacVal > 0;\n  } else if (hvacStatus.status) {\n    hvacOn = String(hvacStatus.status).toLowerCase() === 'on';\n  }\n  if (!hvacOn) hvacVal = 0;\n  hvacSrc = hvacStatus.source || hvacStatus._endpoint || '?';\n  hvacText = `Fan ${hvacOn ? 'ON' : 'OFF'} (${hvacVal}%)  src=${hvacSrc}`;\n}\nconst hvacDot = hvacOn ? '🟢' : '🔴';\n\n// ----- Seat -----\nconst heatStatus = statuses['dash/status/seat#seat.heating'];\nconst coolStatus = statuses['dash/status/seat#seat.heating_cooling'];\nconst heatingVal = heatStatus ? Number(heatStatus.value ?? 0) : 0;\nconst hcVal = coolStatus ? Number(coolStatus.value ?? 0) : 0;\nconst heatOn = (heatingVal !== 0) || (hcVal > 0);\nconst coolOn = (hcVal < 0);\nconst heatDot = heatOn ? '🔴' : '⚪';\nconst coolDot = coolOn ? '🔵' : '⚪';\nconst heatSrc = heatStatus ? (heatStatus.source || heatStatus._endpoint || '?') : '-';\nconst coolSrc = coolStatus ? (coolStatus.source || coolStatus._endpoint || '?') : '-';\nconst heatText = heatStatus ? `heating=${heatingVal} hc=${hcVal}  src=${heatSrc}` : 'awaiting ECU...';\nconst coolText = coolStatus ? `hc=${hcVal}  src=${coolSrc}` : 'awaiting ECU...';\n\n// ----- Battery -----\nconst voltage = signals['sim/battery/voltage'];\nconst current = signals['sim/battery/current'];\nconst soc = signals['sim/battery/soc'];\n\n// ----- Change detection -----\nconst prev = flow.get('lastStatusSnap') || {};\nconst snap = { hvacVal, heatingVal, hcVal, voltage, current, soc, hvacOn, heatOn, coolOn };\nflow.set('lastStatusSnap', snap);\n\n// ----- Notifications -----\nlet notif = null;\nif (flow.get('engineStarted')) {\n  if (prev.hvacOn === false && hvacOn) notif = { payload: { text: 'Fan turned ON', kind: 'on' } };\n  else if (prev.hvacOn === true && !hvacOn) notif = { payload: { text: 'Fan turned OFF', kind: 'off' } };\n  else if (prev.heatOn === false && heatOn) notif = { payload: { text: 'Seat heating turned ON', kind: 'on' } };\n  else if (prev.heatOn === true && !heatOn) notif = { payload: { text: 'Seat heating turned OFF', kind: 'off' } };\n  else if (prev.coolOn === false && coolOn) notif = { payload: { text: 'Seat cooling turned ON', kind: 'on' } };\n  else if (prev.coolOn === true && !coolOn) notif = { payload: { text: 'Seat cooling turned OFF', kind: 'off' } };\n}\n\nreturn [\n  { payload: `${hvacDot}  ${hvacText}` },\n  { payload: `${heatDot}  ${heatText}` },\n  { payload: `${coolDot}  ${coolText}` },\n  (prev.hvacVal !== hvacVal) ? { payload: hvacVal } : null,\n  (prev.heatingVal !== heatingVal) ? { payload: heatOn } : null,\n  (prev.hcVal !== hcVal) ? { payload: coolOn } : null,\n  (voltage !== undefined && prev.voltage !== voltage) ? { payload: voltage } : null,\n  (current !== undefined && prev.current !== current) ? { payload: current } : null,\n  (soc !== undefined && prev.soc !== soc) ? { payload: soc } : null,\n  notif\n];",
    "outputs": 10,
    "x": 560,
    "y": 1200,
    "wires": [
      [
        "ev-range-text-hvac-status"
      ],
      [
        "ev-range-text-seat-heat-status"
      ],
