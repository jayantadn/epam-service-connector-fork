  {
    "id": "ev-range-drive-button",
    "type": "ui-template",
    "z": "ev-range-flow",
    "group": "ev-range-group-engine",
    "page": "",
    "ui": "",
    "name": "Engine Start/Stop",
    "order": 1,
    "width": "3",
    "height": "6",
    "format": "<template>\n  <div class=\"engine-btn-wrap\" @click=\"toggle\">\n    <div class=\"engine-btn-outer\" :class=\"{ on: on }\">\n      <div class=\"engine-btn-bezel\">\n        <div class=\"engine-btn-inner\">\n          <div class=\"engine-btn-line line1\">ENGINE</div>\n          <div class=\"engine-btn-line line2\">START</div>\n          <div class=\"engine-btn-line line3\">STOP</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"engine-btn-status\" :class=\"{ on: on }\">{{ on ? 'ENGINE ON' : 'PRESS TO START' }}</div>\n  </div>\n</template>\n<style>\n.engine-btn-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;user-select:none;padding:2px;width:100%;}\n.engine-btn-outer{width:170px;height:170px;min-width:170px;min-height:170px;max-width:170px;max-height:170px;flex:0 0 170px;aspect-ratio:1/1;box-sizing:border-box;border-radius:50%;background:radial-gradient(circle at 50% 35%, #4a4a4a 0%, #1a1a1a 70%);padding:6px;box-shadow:0 6px 14px rgba(0,0,0,0.6), inset 0 -3px 6px rgba(0,0,0,0.5), inset 0 3px 6px rgba(255,255,255,0.08);transition:all 0.2s ease;border:2px solid #b22222;}\n.engine-btn-outer.on{border-color:#27ae60;box-shadow:0 0 30px rgba(39,174,96,0.6), inset 0 -4px 8px rgba(0,0,0,0.5);}\n.engine-btn-outer:active{transform:translateY(2px);box-shadow:0 4px 10px rgba(0,0,0,0.6), inset 0 4px 8px rgba(0,0,0,0.6);}\n.engine-btn-bezel{width:100%;height:100%;box-sizing:border-box;border-radius:50%;background:linear-gradient(145deg,#2b2b2b,#101010);padding:8px;border:1px solid #555;}\n.engine-btn-inner{width:100%;height:100%;box-sizing:border-box;border-radius:50%;background:radial-gradient(circle at 50% 40%, #c0392b 0%, #7a1d12 80%);display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;font-family:'Arial Black','Helvetica',sans-serif;text-shadow:0 1px 2px rgba(0,0,0,0.8);box-shadow:inset 0 -6px 12px rgba(0,0,0,0.5), inset 0 6px 12px rgba(255,255,255,0.15);transition:background 0.3s;}\n.engine-btn-outer.on .engine-btn-inner{background:radial-gradient(circle at 50% 40%, #27ae60 0%, #145a32 80%);}\n.engine-btn-line{font-weight:900;letter-spacing:1px;line-height:1.05;}\n.line1{font-size:13px;opacity:0.85;}\n.line2{font-size:22px;}\n.line3{font-size:13px;opacity:0.85;}\n.engine-btn-status{margin-top:6px;font-family:monospace;font-size:13px;font-weight:bold;letter-spacing:1px;color:#888;}\n.engine-btn-status.on{color:#27ae60;}\n</style>\n<script>\nexport default {\n  data(){return {on:false}},\n  watch:{msg(m){if(m&&typeof m.payload==='boolean')this.on=m.payload}},\n  methods:{toggle(){this.on=!this.on;this.send({payload:this.on})}}\n}\n</script>",
    "storeOutMessages": true,
    "passthru": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 120,
    "y": 100,
    "wires": [
      [
        "ev-range-drive-handle"
      ]
    ]
