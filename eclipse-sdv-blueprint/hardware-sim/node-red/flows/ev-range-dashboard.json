    "head": "",
    "format": "<template>\n  <div class=\"led-row\">\n    <div class=\"led-title\">FAN</div>\n    <div class=\"led-dot\" :style=\"dotStyle\"></div>\n  </div>\n</template>\n<style>\n.led-row{display:flex;align-items:center;justify-content:center;gap:18px;padding:10px 6px;width:100%;height:100%;}\n.led-dot{width:64px;height:64px;min-width:64px;border-radius:50%;border:3px solid #0a0a0a;transition:all 0.4s ease;}\n.led-title{font-family:'Roboto Mono',monospace;font-size:15px;font-weight:bold;letter-spacing:3px;color:#bbb;}\n</style>\n<script>\nexport default {\n  data(){return {color:'#1a1a1a',glow:false}},\n  computed:{\n    dotStyle(){return {background:this.color, boxShadow:this.glow?`0 0 22px 5px ${this.color}, inset 0 -6px 12px rgba(0,0,0,0.55)`:'inset 0 -6px 12px rgba(0,0,0,0.55)'}}\n  },\n  watch:{msg(m){if(!m||m.payload==null)return;const s=String(m.payload);if(s.includes('\\uD83D\\uDFE2')){this.color='#1e7a3e';this.glow=true;}else if(s.includes('\\uD83D\\uDD35')){this.color='#1f6ea8';this.glow=true;}else if(s.includes('\\uD83D\\uDD34')){this.color='#a02a1e';this.glow=true;}else{this.color='#1a1a1a';this.glow=false;}}}\n}\n</script>",
