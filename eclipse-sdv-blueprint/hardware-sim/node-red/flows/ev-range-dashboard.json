  {
    "id": "ev-range-battery-meter",
    "type": "ui-template",
    "z": "ev-range-tab",
    "group": "ev-range-group-battery",
    "page": "",
    "ui": "",
    "name": "Battery meter",
    "order": 4,
    "width": "6",
    "height": "3",
    "head": "",
    "format": "<template>\n  <div class=\"bm-wrap\">\n    <div class=\"bm-body\">\n      <div class=\"bm-cap\"></div>\n      <div class=\"bm-shell\">\n        <div class=\"bm-fill\" :style=\"fillStyle\"></div>\n        <div class=\"bm-label\">{{ soc }}%</div>\n      </div>\n    </div>\n    <div class=\"bm-sub\">{{ statusText }}</div>\n  </div>\n</template>\n<style>\n.bm-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;height:100%;padding:6px;font-family:'Roboto Mono',monospace;}\n.bm-body{display:flex;align-items:center;}\n.bm-cap{width:10px;height:30px;background:#222;border:2px solid #555;border-right:none;border-radius:4px 0 0 4px;}\n.bm-shell{position:relative;width:260px;height:54px;background:#0a0a0a;border:3px solid #555;border-radius:6px;overflow:hidden;box-shadow:inset 0 -3px 6px rgba(0,0,0,0.6),0 4px 10px rgba(0,0,0,0.5);}\n.bm-fill{position:absolute;top:0;left:0;bottom:0;transition:width 0.5s ease,background 0.5s ease;box-shadow:inset 0 -4px 8px rgba(0,0,0,0.35);}\n.bm-label{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:900;color:#fff;text-shadow:0 1px 3px rgba(0,0,0,0.9);letter-spacing:2px;}\n.bm-sub{margin-top:8px;font-size:12px;letter-spacing:3px;color:#888;}\n</style>\n<script>\nexport default {\n  data(){return {soc:0}},\n  computed:{\n    color(){if(this.soc<=15)return '#e74c3c';if(this.soc<=40)return '#f39c12';return '#27ae60';},\n    fillStyle(){return {width:this.soc+'%', background:`linear-gradient(180deg, ${this.color}, ${this.color}dd)`};},\n    statusText(){if(this.soc<=15)return 'CRITICAL';if(this.soc<=40)return 'LOW';if(this.soc<=80)return 'OK';return 'FULL';}\n  },\n  watch:{msg(m){if(!m||m.payload==null)return;const n=Number(m.payload);if(!isNaN(n))this.soc=Math.max(0,Math.min(100,Math.round(n)));}}\n}\n</script>",
